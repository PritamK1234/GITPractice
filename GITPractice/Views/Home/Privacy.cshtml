@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-dark text-white rounded-top-3">
            <h3 class="mb-0 fw-bold">
                <i class="bi bi-shield-lock-fill me-2"></i> @ViewData["Title"]
            </h3>
        </div>
        <div class="card-body">
            <p class="lead text-muted">
                We value your privacy and are committed to protecting your personal information.
            </p>

            <h5 class="fw-bold mt-4">Information We Collect</h5>
            <p>
                This section explains what data we collect when you use our site, such as account details,
                usage information, and cookies.
            </p>

            <h5 class="fw-bold mt-4">How We Use Your Information</h5>
            <p>
                We use your information to improve our services, personalize your experience, and ensure
                secure access to our platform.
            </p>

            <h5 class="fw-bold mt-4">Your Rights</h5>
            <p>
                You have the right to access, update, or delete your personal data. Contact us if you wish
                to exercise these rights.
            </p>

            <h5 class="fw-bold mt-4">Contact Us1</h5>
            <p>
                If you have any questions about this Privacy Policy, please reach out to our support team 1.
            </p>

            <h5 class="fw-bold mt-4">Contact Us2</h5>
            <p>
                If you have any questions about this Privacy Policy, please reach out to our support team 2.
            </p>

            <h5 class="fw-bold mt-4">Contact Us3</h5>
            <p>
                If you have any questions about this Privacy Policy, please reach out to our support team 3.
            </p>
        </div>
    </div>
</div>